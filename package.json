{
  "name": "ecommerce-front",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.2.13",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "next build",
    "dev": "bun run index.js",
    "dev:next": "next dev",
    "lint": "next lint",
    "start": "bun run index.js",
    "start:cluster": "ENABLE_NODE_CLUSTER=true bun run index.js",
    "worker:telegram": "bun run scripts/telegram-order-worker.mjs",
    "api:serve": "bun run scripts/bun-api-server.ts",
    "telegram:worker": "bun run scripts/telegram-order-worker.mjs",
    "start:stack": "sh -c 'ENABLE_NODE_CLUSTER=true bun run index.js & bun run scripts/telegram-order-worker.mjs & wait'",
    "build:start": "bun run build && bun run start:stack",
    "postbuild": "next-sitemap --config next-sitemap.config.js"
  },
  "dependencies": {
    "@auth0/nextjs-auth0": "^3.5.0",
    "@bradgarropy/next-seo": "^1.2.0",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@graphcms/rich-text-react-renderer": "^0.6.1",
    "@mui/icons-material": "^5.11.16",
    "@mui/material": "^5.13.1",
    "@next-auth/mongodb-adapter": "^1.1.3",
    "@nextui-org/react": "^2.3.6",
    "@nextui-org/skeleton": "^2.0.27",
    "@sendgrid/mail": "^7.7.0",
    "@tawk.to/tawk-messenger-react": "^2.0.2",
    "@vercel/analytics": "^1.0.2",
    "@vercel/speed-insights": "^1.0.8",
    "axios": "^1.4.0",
    "eslint": "8.40.0",
    "eslint-config-next": "^14.1.4",
    "express-validator": "^7.0.1",
    "framer-motion": "^11.1.9",
    "grammy": "^1.42.0",
    "graphql-request": "^6.1.0",
    "gsap": "^3.12.5",
    "loadash": "^1.0.0",
    "micro": "^10.0.1",
    "moment": "^2.29.4",
    "mongodb": "^5.5.0",
    "mongoose": "^7.1.1",
    "next": "^14.1.4",
    "next-auth": "^4.24.7",
    "next-pwa": "^5.6.0",
    "next-reveal": "^1.0.6",
    "next-sitemap": "^4.1.3",
    "next-themes": "^0.4.6",
    "nprogress": "^0.2.0",
    "parallax-controller": "^1.7.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.9.0",
    "react-loading-skeleton": "^3.3.1",
    "react-scroll": "^1.8.9",
    "react-scroll-parallax": "^3.4.2",
    "react-spinners": "^0.13.8",
    "react-spring": "^9.7.1",
    "react-syntax-highlighter": "^15.5.0",
    "slugify": "^1.6.6",
    "sonner": "^1.4.41",
    "stripe": "^12.5.0",
    "styled-components": "^5.3.9",
    "sweetalert2": "^11.7.5",
    "sweetalert2-react-content": "^5.0.7",
    "twilio": "^4.11.2",
    "typewriter-effect": "^2.19.0",
    "uuid": "^9.0.0"
  }
}
